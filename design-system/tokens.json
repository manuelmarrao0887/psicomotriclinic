{
  "$meta": {
    "name": "Psicomotriclinic Hub — Design System",
    "version": "2.0.0-alpha.36",
    "source": "extraído do código real (app/src/index.css + ui.jsx), verificado em claro e escuro",
    "note": "navy tem dois papéis: como TEXTO (text.strong, inverte no dark) e como FUNDO (brand.bg, mantém-se escuro). Nunca usar o mesmo token para ambos."
  },
  "brand": {
    "essence": "A Casa · Clínica · Formação — o corpo que pensa. Psicomotricidade com rigor clínico e proximidade humana.",
    "personality": ["serena não fria", "rigorosa não burocrática", "próxima não informal", "confiável e discreta"],
    "tagline": "Uma casa para o corpo que pensa.",
    "wordmark": "PSICOMOTRICLINIC (PSICOMOTRI 700 + CLINIC 400), tracking -0.01em",
    "voice": "pt-PT, voz ativa, específica; erros explicam causa + correção; nomear pelo que as pessoas reconhecem"
  },
  "color": {
    "ramp": {
      "navy":    { "50":"#EAEEF3","100":"#D5DCE6","200":"#AAB9CC","300":"#7E95B0","400":"#4C6684","500":"#2E4A6B","600":"#1E3556","700":"#152741","800":"#0E1B30","900":"#08111F" },
      "amber":   { "50":"#FDF3E3","100":"#FAE4C2","200":"#F5D9A8","300":"#EFC178","400":"#E8A13C","500":"#C97A1F","600":"#A5620F","700":"#8A5011","800":"#6B3E0D","900":"#4A2B0A" },
      "neutral": { "0":"#FFFFFF","50":"#FBFAF7","100":"#F5F2EC","200":"#EAE6DD","300":"#D9D3C5","400":"#B8B2A4","500":"#8A8A86","600":"#6E6E68","700":"#55554F","800":"#3C3C3B","900":"#152741" }
    },
    "gradient": {
      "amber-avatar": "radial-gradient(circle at 30% 30%, #E8A13C, #C9791A)",
      "navy-surface": "linear-gradient(135deg, #152741, #0E1B30)",
      "progress":     "linear-gradient(90deg, #E8A13C, #F2B65C)"
    },
    "brand": {
      "navy":   { "value": "#152741", "use": "cor primária — fundo de botões/sidebar, texto de títulos" },
      "cream":  { "value": "#F5F2EC", "use": "fundo subtil / superfícies secundárias" },
      "paper":  { "value": "#FBFAF7", "use": "fundo de página (warm off-white)" },
      "amber":  { "value": "#E8A13C", "use": "acento — indicadores ativos, avatares, destaques (NÃO como texto sobre claro)" },
      "sage":   { "value": "#8DBF94", "use": "acento secundário verde" },
      "sky":    { "value": "#B9CDE0", "use": "acento secundário azul" }
    },
    "semantic": {
      "light": {
        "surface":       "#FFFFFF",
        "surface-2":     "#F5F2EC",
        "border":        "#EAE6DD",
        "border-strong": "#D9D3C5",
        "text":          "#3C3C3B",
        "text-2":        "#55554F",
        "text-muted":    "#6E6E68",
        "text-strong":   "#152741",
        "brand-bg":      "#152741",
        "brand-bg-hover":"#1E3556",
        "brand-contrast":"#F7F4EE"
      },
      "dark": {
        "surface":       "#1A2A44",
        "surface-2":     "#152741",
        "border":        "#2A3D5C",
        "border-strong": "#3A4D6C",
        "text":          "#D8D3C7",
        "text-2":        "#A9A39A",
        "text-muted":    "#8A9AAE",
        "text-strong":   "#E8E3D7",
        "brand-bg":      "#0E1B30",
        "brand-bg-hover":"#16233A",
        "brand-contrast":"#E8E3D7",
        "page-bg":       "#0E1A2C"
      }
    },
    "state": {
      "comment": "pares fundo/texto verificados AA (texto pequeno 4.5:1) para badges/tags",
      "success":  { "bg": "#DDEADE", "fg": "#2F6139" },
      "danger":   { "bg": "#F4E0E0", "fg": "#A82E2E" },
      "warning":  { "bg": "#F5E5CD", "fg": "#8A5011" },
      "info":     { "bg": "#DCE7F0", "fg": "#1E3556" },
      "neutral":  { "bg": "#F5F2EC", "fg": "#3C3C3B" }
    }
  },
  "typography": {
    "families": {
      "display": "DM Sans (pesos 300/400/500/600/700) — títulos e corpo",
      "mono":    "JetBrains Mono (400/500) — labels, dados, eyebrows (uppercase + letter-spacing .08em)"
    },
    "base": { "size": "15px", "lineHeight": 1.55 },
    "scale": {
      "eyebrow": "11px mono uppercase",
      "caption": "12px",
      "body-sm": "13px",
      "body":    "14–15px",
      "title-sm":"18px",
      "title":   "24px",
      "display": "30–36px (weight 300, letter-spacing -0.025em)"
    },
    "weights": { "display": 300, "body": 400, "medium": 500, "semibold": 600, "bold": 700 }
  },
  "radius": { "sm": "8px", "md": "10px", "card": "14px", "modal": "18px", "pill": "999px" },
  "shadow": {
    "card":  "0 4px 14px rgba(21,39,65,.06)",
    "modal": "0 24px 64px rgba(21,39,65,.18)",
    "toast": "0 12px 36px rgba(21,39,65,.25)"
  },
  "spacing": { "rhythm": "4 / 8 px", "scale": [4, 8, 12, 16, 20, 24, 32, 40, 48, 60], "card-pad": { "desktop": "22px", "mobile": "16px" }, "page-pad": { "desktop": "28px 40px 60px", "mobile": "16px 16px 60px" }, "container-max": "1180px", "sidebar-w": "260px" },
  "zIndex": { "base": 0, "sticky": 10, "modal": 200, "toast": 999 },
  "icon": { "sizes": { "inline": "13-16", "nav": "17-20", "tabbar": "22" }, "touchTarget": "44x44 min", "style": "SVG set próprio, traço 1.5-2px, um só estilo" },
  "breakpoint": { "mobile": "< 900px (bottom-tab)", "desktop": "≥ 900px (sidebar)" },
  "motion": { "ease": "cubic-bezier(.32,.72,0,1)", "durations": "150–300ms micro; ≤400ms transições", "reducedMotion": "respeitado (prefers-reduced-motion)" },
  "a11y": {
    "contrastText": "4.5:1 (AA) para texto normal; 3:1 para texto grande/ícones",
    "focus": "anel visível 2px accent",
    "darkMode": "reatribuição de tokens (não inversão); contraste testado por tema"
  }
}
