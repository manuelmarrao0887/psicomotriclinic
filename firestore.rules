rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // Helpers
    // ─────────────────────────────────────────────────────────────
    function isSignedIn() { return request.auth != null; }
    function profile()    { return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data; }
    function role()       { return isSignedIn() ? profile().role : 'none'; }
    function isDirector() { return isSignedIn() && role() == 'director'; }
    function isStaff()    { return isSignedIn() && (role() == 'director' || role() == 'professional'); }

    // Bootstrap: o email do admin conhecido pode auto-provisionar-se como
    // director (a 1ª conta director não pode ser criada por um director que
    // ainda não existe). Ajustar/rodar este email conforme necessário.
    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.token.email == 'manuelsousamarrao@gmail.com';
    }

    // Dono do documento clínico: staff, ou um utilizador cujo uid está
    // denormalizado em parent_user_ids / professional_ids do próprio doc.
    // (A denormalização é feita nas Cloud Actions do cliente ao criar/editar.)
    function ownsDoc() {
      return isSignedIn() && (
        request.auth.uid in resource.data.get('parent_user_ids', []) ||
        request.auth.uid in resource.data.get('professional_ids', [])
      );
    }

    // Dono do paciente referenciado por patient_id (usado em create, onde
    // ainda não existe `resource`). Faz um get() ao paciente.
    function ownsPatient(pid) {
      return isSignedIn() && (
        isStaff() ||
        request.auth.uid in get(/databases/$(database)/documents/patients/$(pid)).data.get('parent_user_ids', [])
      );
    }

    // Verifica que a atualização NÃO mexe em campos proibidos (ex.: role).
    function keeps(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // ─────────────────────────────────────────────────────────────
    // Perfis
    //  • Leitura: qualquer autenticado (listas de equipa/utilizadores).
    //  • Criação: só o próprio uid ou a direção.
    //  • Atualização: o próprio ou a direção — MAS `role` e `active` são
    //    imutáveis para o próprio (só a direção os pode mudar). Isto fecha
    //    a escalada de privilégios via updateDoc(profiles/self,{role:'director'}).
    //  • O papel de auto-registo é sempre imposto no cliente/servidor como
    //    'parent'; nunca aceitar 'director'/'professional' de auto-registo.
    // ─────────────────────────────────────────────────────────────
    match /profiles/{uid} {
      allow read: if isSignedIn();
      allow create: if isDirector()
        || (request.auth.uid == uid && isBootstrapAdmin())
        || (request.auth.uid == uid && request.resource.data.role == 'parent');
      allow update: if isDirector()
        || (request.auth.uid == uid && isBootstrapAdmin())
        || (request.auth.uid == uid && keeps('role') && keeps('active'));
      allow delete: if isDirector();
    }

    // ─────────────────────────────────────────────────────────────
    // Equipa
    // ─────────────────────────────────────────────────────────────
    match /professionals/{id} { allow read: if isSignedIn(); allow write: if isStaff(); }

    // ─────────────────────────────────────────────────────────────
    // Pacientes — leitura só para staff ou responsável vinculado.
    // ─────────────────────────────────────────────────────────────
    match /patients/{id} {
      allow read: if isStaff() || (isSignedIn() && request.auth.uid in resource.data.get('parent_user_ids', []));
      allow write: if isStaff();
    }

    // ─────────────────────────────────────────────────────────────
    // Sessões (agenda) — clínico, staff ou responsável dono.
    // ─────────────────────────────────────────────────────────────
    match /sessions/{id} {
      allow read: if isStaff() || ownsDoc();
      allow write: if isStaff();
    }

    // ─────────────────────────────────────────────────────────────
    // Financeiro — confidencial. Só staff lê; só direção escreve.
    // (Responsáveis não acedem ao livro financeiro da clínica.)
    // ─────────────────────────────────────────────────────────────
    // Pagamentos: staff vê tudo; o responsável vê apenas os dos seus filhos
    // (parent_user_ids denormalizado no doc). Livro de custos fica só-staff.
    match /payments/{id}       { allow read: if isStaff() || ownsDoc(); allow write: if isDirector(); }
    match /overheads/{id}      { allow read: if isStaff(); allow write: if isDirector(); }
    match /variable_costs/{id} { allow read: if isStaff(); allow write: if isDirector(); }

    // ─────────────────────────────────────────────────────────────
    // Pedidos de troca — o requerente tem de ser o próprio utilizador.
    // ─────────────────────────────────────────────────────────────
    match /schedule_requests/{id} {
      allow read:   if isStaff() || ownsDoc()
        || (isSignedIn() && resource.data.requested_by_id == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.requested_by_id == request.auth.uid;
      allow update, delete: if isStaff();
    }

    // ─────────────────────────────────────────────────────────────
    // Visitas (métricas) — cada um regista a sua; só direção lê.
    // ─────────────────────────────────────────────────────────────
    match /visits/{id} {
      allow read: if isDirector();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // Clínico sensível — staff ou responsável/profissional dono do doc.
    // A leitura em lista exige que a query do cliente filtre por
    // array-contains parent_user_ids/professional_ids (ver store.jsx).
    // ─────────────────────────────────────────────────────────────
    match /anamnesis/{id} {
      allow read: if isStaff() || ownsDoc();
      allow write: if isStaff();
    }

    match /intervention_plans/{id} {
      allow read: if isStaff() || ownsDoc();
      allow write: if isStaff();
    }

    // Notas de sessão: staff escreve tudo. Responsável dono pode criar UMA
    // nota de cancelamento (status=cancelado, cancelled_by_user=true) ligada
    // a um paciente que lhe pertence — nada mais.
    match /session_notes/{id} {
      allow read: if isStaff() || ownsDoc();
      allow create: if isStaff()
        || (isSignedIn()
            && request.resource.data.cancelled_by_user == true
            && request.resource.data.status == "cancelado"
            && ownsPatient(request.resource.data.patient_id)
            && request.auth.uid in request.resource.data.get('parent_user_ids', []));
      allow update, delete: if isStaff();
    }

    // ─────────────────────────────────────────────────────────────
    // Diário de comportamento — responsável dono ou staff.
    // ─────────────────────────────────────────────────────────────
    match /behavior_diary/{id} {
      allow read: if isStaff() || ownsDoc();
      allow create: if isSignedIn()
        && ownsPatient(request.resource.data.patient_id)
        && request.resource.data.by_user_id == request.auth.uid;
      allow update, delete: if isStaff()
        || (isSignedIn() && resource.data.by_user_id == request.auth.uid);
    }

    // ─────────────────────────────────────────────────────────────
    // Mensagens responsável ↔ profissional.
    // ─────────────────────────────────────────────────────────────
    match /parent_messages/{id} {
      allow read: if isStaff() || ownsDoc()
        || (isSignedIn() && resource.data.from_user_id == request.auth.uid);
      allow create: if isSignedIn()
        && ownsPatient(request.resource.data.patient_id)
        && request.resource.data.from_user_id == request.auth.uid;
      // Só staff pode responder/marcar lido.
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    // ─────────────────────────────────────────────────────────────
    // Biblioteca de exercícios de casa — leitura a autenticados
    // (não é dado pessoal); escrita a staff.
    // ─────────────────────────────────────────────────────────────
    match /home_exercises_library/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // Atribuições e conclusões de prática em casa — ligadas a um paciente.
    match /home_practice_assignments/{id} {
      allow read: if isStaff() || ownsDoc();
      allow write: if isStaff();
    }
    match /home_practice_completions/{id} {
      allow read: if isStaff() || ownsDoc();
      allow create: if isSignedIn()
        && ownsPatient(request.resource.data.patient_id)
        && request.resource.data.by_user_id == request.auth.uid;
      allow update, delete: if isStaff();
    }

    // ─────────────────────────────────────────────────────────────
    // Lista de espera (CRM) — dados de leads; só staff.
    // ─────────────────────────────────────────────────────────────
    match /waitlist/{id} { allow read, write: if isStaff(); }

    // ─────────────────────────────────────────────────────────────
    // Auditoria — staff cria; só direção lê; imutável.
    // ─────────────────────────────────────────────────────────────
    match /audit_log/{id} {
      allow read: if isDirector();
      allow create: if isStaff();
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // Comunicações da direção — leitura a autenticados (portal filtra
    // por audience no cliente); escrita só direção.
    // ─────────────────────────────────────────────────────────────
    match /announcements/{id} { allow read: if isSignedIn(); allow write: if isDirector(); }

    // ─────────────────────────────────────────────────────────────
    // Lembretes — escritos só pela Cloud Function (Admin SDK ignora regras).
    // ─────────────────────────────────────────────────────────────
    match /reminders/{id} { allow read: if isDirector(); allow write: if false; }

    // ─────────────────────────────────────────────────────────────
    // Default deny — qualquer coleção não listada acima é negada.
    // (NÃO adicionar match /{document=**} permissivo.)
    // ─────────────────────────────────────────────────────────────
  }
}
